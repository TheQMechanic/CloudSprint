rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // Only the authenticated owner can read/write their profile.
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.data.keys().size() <= 10
                   && request.resource.size() < 20000;

      // Progress sub-documents (e.g. /users/{uid}/progress/{roadmapId})
      match /progress/{docId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null
                     && request.auth.uid == userId
                     && request.resource.data.keys().size() <= 15
                     && request.resource.size() < 50000;
      }

      // Notes sub-collection
      match /notes/{noteId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null
                     && request.auth.uid == userId
                     && request.resource.data.text is string
                     && request.resource.data.text.size() < 5000;
      }

      // Activity sub-collection
      match /activity/{eventId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null
                     && request.auth.uid == userId
                     && request.resource.data.keys().size() <= 15
                     && request.resource.size() < 5000;
      }
    }
  }
}
